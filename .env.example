# LLM extraction (Anthropic)
ANTHROPIC_API_KEY=

# Embeddings (Voyage — used at load time and query time)
VOYAGE_API_KEY=

# Database (Neon Postgres; the Vercel Neon integration sets this for you)
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# PDF storage (Vercel Blob)
BLOB_READ_WRITE_TOKEN=
